<!DOCTYPE html>
<html>

<head>
    <title>Classes</title>
    <link href="https://cdn.jsdelivr.net/npm/bootstrap@5.3.3/dist/css/bootstrap.min.css" rel="stylesheet">
    <link rel="stylesheet" href="/css/style.css">
</head>

<body class="search-background">
<%- include('partials/navbar') %>

<div class="container mt-4">
    <div class="d-flex justify-content-between align-items-center white-button mb-4">
        <h2>Class Lists</h2>
        
        <!-- Compact Filter Form -->
        <form action="/classes" method="GET" class="d-flex align-items-center gap-2" id="filterForm">
            <label for="classId" class="text-nowrap mb-0 me-1 text-white">Filter by Class:</label>
            <select name="classId" id="classId" class="form-select form-select-sm" style="width: auto;" onchange="document.getElementById('filterForm').submit();">
                <option value="">All Classes</option>
                <% if (typeof classes !== 'undefined' && classes) { %>
                    <% classes.forEach(function(cls) { %>
                        <option value="<%= cls %>" <%= typeof selectedClass !== 'undefined' && selectedClass === cls ? 'selected' : '' %>>
                            <%= cls %>
                        </option>
                    <% }) %>
                <% } %>
            </select>
        </form>
    </div>

    <!-- Students Table -->
    <div class="card shadow-sm">
        <div class="card-body p-0">
            <% if (typeof students !== 'undefined' && students && students.length > 0) { %>
                <div class="table-responsive">
                    <table class="table table-hover align-middle mb-0">
                        <thead class="table-light">
                            <tr>
                                <th style="width: 12%;">ID</th>
                                <th style="width: 12%;">Photo</th>
                                <th style="width: 22%;">Name</th>
                                <th style="width: 12%;">Class</th>
                                <th style="width: 12%;">Status</th>
                                <th style="width: 12%;">Remarks</th>
                                <th style="width: 12%;">Module Slot</th>
                                <th style="width: 12%;">Details</th>
                                <% if (user && user.role === 'admin') { %>
                                    <th style="width: 16%;">Actions</th>
                                <% } %>
                            </tr>
                        </thead>
                        <tbody>
                            <% students.forEach(function(student) { %>
                                <tr>
                                    <td><strong><%= student.student_id %></strong></td>
                                    <td>
                                        <% if (student.image) { %>
                                            <img src="/<%= student.image %>" alt="<%= student.student_name %>" class="rounded-circle img-thumbnail" style="width: 50px; height: 50px; object-fit: cover;">
                                        <% } else { %>
                                            <div class="rounded-circle bg-secondary d-flex align-items-center justify-content-center text-white" style="width: 50px; height: 50px;">
                                                <%= (student.student_name && student.student_name.length > 0) ? student.student_name.charAt(0) : '?' %>
                                            </div>
                                        <% } %>
                                    </td>
                                    <td><%= student.student_name %></td>
                                    <td>
                                        <span class="badge bg-secondary"><%= student.class_id %></span>
                                    </td>
                                    <td>
                                        <% if (student.status === 'Present') { %>
                                             <span class="badge bg-success">Present</span>
                                                
                                            </span>
                                         <% } else if (student.status === 'Late') { %>    <span class="badge bg-warning text-dark">Late</span>

                                         <% } else if (student.status === 'Absent') { %>   <span class="badge bg-danger">Absent</span>

                                        <% } else { %>
                                            <span class="badge bg-warning text-dark">Unmarked</span>
                                        <% } %>
                                    </td>
                                    <td class="text-muted small">
                                        <%= student.remarks || '-' %>
                                    </td>
                                    <td class="text-muted small">
                                        <%= student.module_slot || '-' %>
                                    </td>
                                    <td>
                                        <a href="/students/<%= student.student_id %>" class="btn btn-sm btn-primary">
                                            View
                                        </a>
                                    </td>
                                    <% if (user && user.role === 'admin') { %>
                                        <td class="text-nowrap">
                                            <button type="button" class="btn btn-sm btn-outline-secondary edit-student-btn"
                                                data-id="<%= student.student_id %>"
                                                data-name="<%= student.student_name %>"
                                                data-class="<%= student.class_id %>"
                                                data-module-slot="<%= student.module_slot || '' %>"
                                                data-image="<%= student.image || '' %>">
                                                Edit
                                            </button>
                                            <button type="button" class="btn btn-sm btn-outline-danger delete-student-btn"
                                                data-id="<%= student.student_id %>"
                                                data-name="<%= student.student_name %>">
                                                Delete
                                            </button>
                                        </td>
                                    <% } %>
                                </tr>
                            <% }) %>
                        </tbody>
                    </table>
                </div>
            <% } else { %>
                <div class="text-center py-5">
                    <h5 class="text-muted mb-0">No students found for this class.</h5>
                </div>
            <% } %>

            <% if (user && user.role === 'admin') { %>
                <div class="modal fade" id="editStudentModal" tabindex="-1" aria-hidden="true">
                    <div class="modal-dialog">
                        <div class="modal-content">
                            <div class="modal-header">
                                <h5 class="modal-title">Edit Student</h5>
                                <button type="button" class="btn-close" data-bs-dismiss="modal" aria-label="Close"></button>
                            </div>
                            <div class="modal-body">
                                <input type="hidden" id="editStudentId">
                                <div class="mb-3">
                                    <label class="form-label">Full Name</label>
                                    <input type="text" id="editStudentName" class="form-control" required>
                                </div>
                                <div class="mb-3">
                                    <label class="form-label">Class</label>
                                    <input type="text" id="editClassId" class="form-control" required>
                                </div>
                                <div class="mb-3">
                                    <label class="form-label">Photo Path</label>
                                    <input type="text" id="editImage" class="form-control" placeholder="e.g. uploads/jane.png">
                                </div>
                            </div>
                            <div class="modal-footer">
                                <button type="button" class="btn btn-secondary" data-bs-dismiss="modal">Cancel</button>
                                <button type="button" class="btn btn-primary" onclick="saveStudentEdit()">Save Changes</button>
                            </div>
                        </div>
                    </div>
                </div>
            <% } %>
        </div>
    </div>
</div>

<script src="https://cdn.jsdelivr.net/npm/bootstrap@5.3.3/dist/js/bootstrap.bundle.min.js"></script>
<% if (user && user.role === 'admin') { %>
<script>
    document.querySelectorAll('.edit-student-btn').forEach(function (btn) {
        btn.addEventListener('click', function () {
            document.getElementById('editStudentId').value = btn.dataset.id;
            document.getElementById('editStudentName').value = btn.dataset.name;
            document.getElementById('editClassId').value = btn.dataset.class;
            document.getElementById('editImage').value = btn.dataset.image;
            new bootstrap.Modal(document.getElementById('editStudentModal')).show();
        });
    });

    function saveStudentEdit() {
        const studentId = document.getElementById('editStudentId').value;
        const student_name = document.getElementById('editStudentName').value.trim();
        const class_id = document.getElementById('editClassId').value.trim();
        const image = document.getElementById('editImage').value.trim();

        if (!student_name || !class_id) {
            alert('Name and Class are required.');
            return;
        }

        fetch('/admin/edit-student', {
            method: 'POST',
            headers: { 'Content-Type': 'application/json' },
            body: JSON.stringify({ studentId, student_name, class_id, image })
        })
            .then(function (res) { return res.json(); })
            .then(function (data) {
                if (data.success) {
                    location.reload();
                } else {
                    alert('Failed to update student.');
                }
            })
            .catch(function () { alert('Failed to update student.'); });
    }

    document.querySelectorAll('.delete-student-btn').forEach(function (btn) {
        btn.addEventListener('click', function () {
            const studentId = btn.dataset.id;
            const studentName = btn.dataset.name;

            if (!confirm('Delete student ' + studentName + ' (' + studentId + ')? This cannot be undone.')) {
                return;
            }

            fetch('/admin/remove-student', {
                method: 'POST',
                headers: { 'Content-Type': 'application/json' },
                body: JSON.stringify({ studentId })
            })
                .then(function (res) { return res.json(); })
                .then(function (data) {
                    if (data.success) {
                        btn.closest('tr').remove();
                    } else {
                        alert('Failed to delete student.');
                    }
                })
                .catch(function () { alert('Failed to delete student.'); });
        });
    });
</script>
<% } %>
</body>
</html>