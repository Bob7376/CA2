<!DOCTYPE html>
<html>

<head>

    <title>Classes</title>
    <link href="https://cdn.jsdelivr.net/npm/bootstrap@5.3.3/dist/css/bootstrap.min.css" rel="stylesheet">

</head>

<body class="bg-light">
<%- include('partials/navbar') %>

<div class="container mt-4">
    <div class="d-flex justify-content-between align-items-center mb-4">
        <h2>Class Lists</h2>
        
        <!-- Compact Filter Form -->
        <form action="/classes" method="GET" class="d-flex align-items-center gap-2" id="filterForm">
            <label for="classId" class="text-nowrap mb-0 me-1 text-muted">Filter by Class:</label>
            <select name="classId" id="classId" class="form-select form-select-sm" style="width: auto;" onchange="document.getElementById('filterForm').submit();">
                <option value="">All Classes</option>
                <% classes.forEach(function(cls) { %>
                    <option value="<%= cls %>" <%= selectedClass === cls ? 'selected' : '' %>>
                        <%= cls %>
                    </option>
                <% }) %>
            </select>
        </form>
    </div>

    <!-- Students Table -->
    <div class="card shadow-sm">
        <div class="card-body p-0">
            <% if (students && students.length > 0) { %>
                <div class="table-responsive">
                    <table class="table table-hover align-middle mb-0">
                        <thead class="table-light">
                            <tr>
                                <th style="width: 15%;">ID</th>
                                <th style="width: 15%;">Photo</th>
                                <th style="width: 25%;">Name</th>
                                <th style="width: 15%;">Class</th>
                                <th style="width: 15%;">Status</th>
                                <th style="width: 15%;">Remarks</th>
                                <th style="width: 15%;">Session</th>
                            </tr>
                        </thead>
                        <tbody>
                            <% students.forEach(function(student) { %>
                                <tr>
                                    <td><strong><%= student.student_id %></strong></td>
                                    <td>
                                        <% if (student.image) { %>
                                            <img src="/<%= student.image %>" alt="<%= student.student_name %>" class="rounded-circle img-thumbnail" style="width: 50px; height: 50px; object-fit: cover;">
                                        <% } else { %>
                                            <div class="rounded-circle bg-secondary d-flex align-items-center justify-content-center text-white" style="width: 50px; height: 50px;">
                                                <%= student.student_name.charAt(0) %>
                                            </div>
                                        <% } %>
                                    </td>
                                    <td><%= student.student_name %></td>
                                    <td>
                                        <span class="badge bg-secondary"><%= student.class_id %></span>
                                    </td>
                                    <td>
                                        <% if (student.status) { %>
                                            <span class="badge <%= student.status === 'Present' ? 'bg-success' : 'bg-danger' %>">
                                                <%= student.status %>
                                            </span>
                                        <% } else { %>
                                            <span class="badge bg-warning text-dark">Unmarked</span>
                                        <% } %>
                                    </td>
                                    <td class="text-muted small">
                                        <%= student.remarks || '-' %>
                                    </td>
                                    <td class="text-muted small">
                                        <%= student.session || '-' %>
                                    </td>
                                </tr>
                            <% }) %>
                        </tbody>
                    </table>
                </div>
            <% } else { %>
                <div class="text-center py-5">
                    <h5 class="text-muted mb-0">No students found for this class.</h5>
                </div>
            <% } %>
        </div>
    </div>
</div>
</body>