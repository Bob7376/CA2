<!DOCTYPE html>
<html lang="en">
<head>
    <meta charset="UTF-8">
    <meta name="viewport" content="width=device-width, initial-scale=1.0">
    <title>Admin - Organize Classes</title>
    <link href="https://cdn.jsdelivr.net/npm/bootstrap@5.3.0/dist/css/bootstrap.min.css" rel="stylesheet">
    <link rel="stylesheet" href="https://cdn.jsdelivr.net/npm/bootstrap-icons@1.11.1/font/bootstrap-icons.css">
    <script src="https://cdn.jsdelivr.net/npm/bootstrap@5.3.0/dist/js/bootstrap.bundle.min.js"></script>
    <link rel="stylesheet" href="/css/style.css">
</head>
<body class="search-background">

    <%- include('partials/navbar') %>

<div class="container mt-4">
    <!-- Header Controls -->
    <div class="card shadow-sm border-0 mb-4 green-button text-white">
        <div class="card-body d-flex justify-content-between align-items-center">
            <div>
                <h3 class="mb-0">Class Organizer</h3>
                <p class="text-light-50 small mb-0">Select students from the list below and create a group. You can select students multiple times for different groups!</p>
            </div>
            <!-- Action Controls -->
            <div class="d-flex gap-2">
                <input type="text" id="targetGroupName" class="form-control form-control-sm" placeholder="Group Name (e.g., Group 1)">
                <button type="button" class="btn btn-primary btn-sm text-nowrap" onclick="createNewGroupCard()">
                    <i class="bi bi-folder-plus me-1"></i> Create Group
                </button>
            </div>
        </div>
    </div>

    <!-- 1. DYNAMIC GROUPS CONTAINER -->
    <h5 class="mb-3" style="color: white"><i class="bi bi-folder2-open me-2"></i>Created Groups</h5>
    <div class="accordion mb-5" id="groupAccordion">
        <!-- Starts empty; admin actions dynamically insert cards here -->
        <div id="emptyStateMessage" class="text-muted small p-3 bg-white border rounded text-center mb-3">
            No groups created yet. Select students below and type a group name to create one!
        </div>
    </div>

    <!-- Class Filter Dropdown -->
<div class="row mb-4">
    <div class="col-md-4 col-sm-6">
        <div class="input-group">
            <span class="input-group-text bg-primary text-white">
                <i class="bi bi-filter"></i> Filter Class
            </span>
            <select id="classFilter" class="form-select">
                <option value="all">All Classes</option>
                <% 
                    // Automatically extract unique classes from your student list
                    const uniqueClasses = [...new Set(students.map(s => s.class_id).filter(Boolean))];
                    uniqueClasses.forEach(classId => { 
                %>
                    <option value="<%= classId %>"><%= classId %></option>
                <% }); %>
            </select>
        </div>
    </div>
</div>

    <!-- 2. MASTER STUDENT LIST -->
    <h5 class="mb-3" style="color: white"><i class="bi bi-people me-2"></i>Master Student List</h5>
    <div class="card shadow-sm border-0">
        <div class="table-responsive">
            <table class="table table-hover align-middle mb-0">
                <thead class="table-light">
                    <tr>
                        <th style="width: 5%;" class="ps-3">Select</th>
                        <th style="width: 20%;">Student ID</th>
                        <th style="width: 35%;">Full Name</th>
                        <th style="width: 15%;">Class</th>
                        <th style="width: 15%;">Module Group (Session)</th>
                        <th style="width: 10%;">Current Groups</th>
                    </tr>
                </thead>
                <tbody>
                    <% if (typeof students === 'undefined' || students.length === 0) { %>
                        <tr>
                            <td colspan="6" class="text-center text-muted py-4">No students found.</td>
                        </tr>
                    <% } else { %>
                        <% students.forEach(function(student) { %>
                            <tr id="row_<%= student.student_id %>" class="student-row" data-class="<%= student.class_id %>">
                                <!-- 1. Select Checkbox Column -->
                                 <td class="ps-3">
                                    <input type="checkbox" class="form-check-input student-checkbox" 
                                           value="<%= student.student_id %>" 
                                           data-name="<%= student.student_name %>">
                                </td>
                                
                            <td><code><%= student.student_id %></code></td>
                            <td class="fw-semibold"><%= student.student_name %></td>
                            
                            <td>
                                <span class="badge bg-light text-dark border">
                                    <%= student.class_id %>
                                </span>
                            </td>

                <!-- 5. Module Group Column -->
                            <td>
                                <% if (student.module_slot) { %>
                                <span class="badge bg-info text-dark">
                                    <i class="bi bi-calendar3 me-1"></i><%= student.module_slot %>
                                </span>
                                <% } else { %>
                                    <span class="badge bg-light text-muted border">N/A</span>
                                <% } %>
                            </td>

                <!-- 6. Current Groups Badges Column -->
                            <td>
                                <div class="group-badges-container">
                                    <span class="badge bg-secondary">None</span>
                                </div>
                            </td>
                        </tr>
                    <% }); %>
                <% } %>
            </tbody>
                        </table>
                    </div>
                </div>
            </div>

<script>
let groupCounter = 0;

function createNewGroupCard() {
    const groupNameInput = document.getElementById('targetGroupName');
    const groupName = groupNameInput.value.trim();
    
    if (!groupName) {
        alert('Please type a group name first!');
        return;
    }

    const checkboxes = document.querySelectorAll('.student-checkbox:checked');
    if (checkboxes.length === 0) {
        alert('Please select at least one student to group together.');
        return;
    }

    // Hide the empty state message
    const emptyState = document.getElementById('emptyStateMessage');
    if (emptyState) {
        emptyState.style.display = 'none';
    }

    // Collect student details from checked checkboxes
    let studentsListHTML = '';
    checkboxes.forEach(cb => {
        const studentId = cb.value;
        const studentName = cb.getAttribute('data-name');
        
        // Build items for inside the dynamic folder card
        studentsListHTML += `
            <li class="list-group-item d-flex justify-content-between align-items-center px-2 py-2">
                <div>
                    <i class="bi bi-person-fill text-secondary me-2"></i>
                    <strong>${studentName}</strong>
                </div>
                <span class="badge bg-light text-dark border">ID: ${studentId}</span>
            </li>
        `;

        // Update the visual status badges dynamically (can append multiple badges now!)
        const row = document.getElementById(`row_${studentId}`);
        if (row) {
            const badgesContainer = row.querySelector('.group-badges-container');
            const placeholderBadge = badgesContainer.querySelector('.badge.bg-secondary');
            
            // If it's still showing "None", remove the default "None" badge first
            if (placeholderBadge) {
                placeholderBadge.remove();
            }

            // Create a new green badge for this group assignment
            const newBadge = document.createElement('span');
            newBadge.className = 'badge bg-success me-1 my-1';
            newBadge.innerHTML = `<i class="bi bi-tag-fill me-1"></i>${groupName}`;
            badgesContainer.appendChild(newBadge);
        }

        // Reset the checkbox to unchecked, but DO NOT disable it so it can be selected again
        cb.checked = false;
    });

    // Create and append the new group folder card to the accordion
    const accordionContainer = document.getElementById('groupAccordion');
    const newGroupHTML = `
        <div class="accordion-item shadow-sm border-0 mb-2 rounded overflow-hidden" id="groupCard_${groupCounter}">
            <h2 class="accordion-header" id="heading${groupCounter}">
                <button class="accordion-button collapsed fw-bold text-primary" type="button" data-bs-toggle="collapse" data-bs-target="#collapse${groupCounter}" aria-expanded="false" aria-controls="collapse${groupCounter}">
                    <i class="bi bi-folder-fill me-2 text-warning"></i>
                    ${groupName}
                    <span class="badge bg-primary ms-3 rounded-pill">${checkboxes.length} Students</span>
                </button>
            </h2>
            <div id="collapse${groupCounter}" class="accordion-collapse collapse" aria-labelledby="heading${groupCounter}" data-bs-parent="#groupAccordion">
                <div class="accordion-body bg-white py-2">
                    <ul class="list-group list-group-flush">
                        ${studentsListHTML}
                    </ul>
                </div>
            </div>
        </div>
    `;

    accordionContainer.insertAdjacentHTML('beforeend', newGroupHTML);
    
    // Clear input for the next group creation
    groupNameInput.value = '';
    groupCounter++;
}

</script>
<script>
    document.getElementById('classFilter').addEventListener('change', function() {
        const selectedClass = this.value;
        const rows = document.querySelectorAll('.student-row');

        rows.forEach(row => {
            const studentClass = row.getAttribute('data-class');

            // Show row if "All Classes" is selected or if the row's class matches the selection
            if (selectedClass === 'all' || studentClass === selectedClass) {
                row.style.display = '';
            } else {
                row.style.display = 'none';
            }
        });
    });
</script>
</body>
</html>
