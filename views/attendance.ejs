<!DOCTYPE html>
<html>

<head>
    <title>Attendance Records</title>
    <link href="https://cdn.jsdelivr.net/npm/bootstrap@5.3.3/dist/css/bootstrap.min.css" rel="stylesheet">
    <link rel="stylesheet" href="/css/style.css">
</head>

<body class="search-background">

<%- include('partials/navbar') %>

<div class="container mt-4">

    <div class="d-flex justify-content-between align-items-center white-button mb-4">
        <h2>Attendance Records</h2>
        <div>
            <span class="badge black-button fs-6">
                Teacher Portal
            </span>
        </div>
    </div>

    <div class="card shadow">

        <div class="card-body p-0">

            <% if (students && students.length > 0) { %>

            <div class="table-responsive">

                <table class="table table-hover align-middle mb-0">

                    <thead class="table-dark">
                        <tr>
                            <th>Student ID</th>
                            <th>Name</th>
                            <th>Class</th>
                            <th>Status</th>
                            <th>Remarks</th>
                            <th>Module Slot</th>
                            <th>Action</th>
                        </tr>
                    </thead>

                    <tbody>
                        <% students.forEach(function(student){ %>
                        <tr>
                            <td><strong><%= student.student_id %></strong></td>
                            <td><%= student.student_name %></td>
                            <td><span class="badge bg-secondary"><%= student.class_id %></span></td>
                            
                            <!-- Status Dropdown Form -->
                            <td>
                                <form id="form-<%= student.student_id %>" action="/attendance/update/<%= student.attendance_id || student.student_id %>" method="POST">
                                    <input type="hidden" name="student_id" value="<%= student.student_id %>">
                                    <select name="status" class="form-select form-select-sm" required>
                                        <option value="" disabled <%= !student.status ? "selected" : "" %>>-- Select --</option>
                                        <option value="Present" <%= student.status === "Present" ? "selected" : "" %>>Present</option>
                                        <option value="Absent" <%= student.status === "Absent" ? "selected" : "" %>>Absent</option>
                                        <option value="Late" <%= student.status === "Late" ? "selected" : "" %>>Late</option>
                                    </select>
                                </form>
                            </td>

                            <!-- Remarks Input linked to the same form -->
                            <td>
                                <input type="text" form="form-<%= student.student_id %>" class="form-control form-control-sm" name="remarks" value="<%= student.remarks || '' %>" placeholder="Optional remark">
                            </td>

                            <td>
                                <%= student.module_slot || student.slot || '-' %>
                            </td>

                            <!-- Submit Button linked to the same form -->
                            <td>
                                <button type="submit" form="form-<%= student.student_id %>" class="btn btn-success btn-sm">Save</button>
                            </td>
                        </tr>
                        <% }) %>
                    </tbody>

                </table>

            </div>

            <% } else { %>

                <div class="text-center p-5">
                    <h4>No attendance records found.</h4>
                </div>

            <% } %>

        </div>

    </div>

</div>

</body>

</html>