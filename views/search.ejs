<!DOCTYPE html>
<html lang="en">
<head>
    <meta charset="UTF-8">
    <meta name="viewport" content="width=device-width, initial-scale=1.0">
    <title>Student Search</title>
    <!-- Bootstrap 5 CSS -->
    <link href="https://cdn.jsdelivr.net/npm/bootstrap@5.3.0/dist/css/bootstrap.min.css" rel="stylesheet">
    <!-- Custom CSS -->
    <link rel="stylesheet" href="/css/style.css">
</head>
<body class="search-background">
<%- include ('partials/navbar.ejs') %>    
<div class="container mt-5">
    <div class="row justify-content-center">
        <div class="col-md-8">
            <h2 class="search-title text-center mb-4">Search Student Database</h2>
            
            <!-- Search Bar Form -->
            <form action="/search" method="GET" class="input-group mb-4 shadow-sm">
                <input type="text" 
                       name="query" 
                       class="form-control form-control-lg" 
                       placeholder="Search by student name or admin number..." 
                       aria-label="Search students">
                <button class="btn green-button" type="submit">Search</button>
            </form>

            <!-- Results Table Card -->
            <div class="card shadow-sm">
                <div class="card-header bg-white font-weight-bold">
                    Search Results
                </div>
                <div class="card-body p-0">
                    <div class="table-responsive">
                        <table class="table table-hover mb-0">
                            <thead class="table-light">
                                <tr>
                                    <th>ID</th>
                                    <th>Photo</th>
                                    <th>Name</th>
                                    <th>Class</th>
                                    <th>Module Slot</th>
                                    <th>Status</th>
                                    <th>Remarks</th>
                                </tr>
                            </thead>
                            <tbody>
                                <!-- If you are using EJS template rendering -->
                                <% if (students && students.length > 0) { %>
                                    <% students.forEach(student => { %>
                                        <tr>
                                            <td class="align-middle"><strong><%= student.student_id %></strong></td>
                                            <td class="align-middle">
                                                <img src="/<%= student.image %>" alt="<%= student.student_name %>" class="rounded-circle img-thumbnail" style="width: 50px; height: 50px; object-fit: cover;">
                                            </td>
                                            <td class="align-middle"><%= student.student_name %></td>
                                            <td class="align-middle"><span class="badge bg-secondary"><%= student.class_id %></span></td>
                                            <td class="align-middle"><span class="badge bg-secondary"><%= student.module_slot || 'N/A' %></span></td>
                                            <td class="align-middle">
                                                <span class="badge <%= student.status === 'Present' ? 'bg-success' : 'bg-danger' %>">
                                                    <%= student.status %>
                                                </span>
                                            </td>
                                            <td class="align-middle text-muted"><%= student.remarks || 'No remarks' %></td>
                                        </tr>
                                    <% }) %>
                                <% } else { %>
                                    <tr>
                                        <td colspan="7" class="text-center text-muted py-4">No student records found. Try another search!</td>
                                    </tr>
                                <% } %>
                            </tbody>
                        </table>
                    </div>
                </div>
            </div>

        </div>
    </div>
</div>

<!-- Bootstrap 5 Bundle JS -->
<script src="https://cdn.jsdelivr.net/npm/bootstrap@5.3.0/dist/js/bootstrap.bundle.min.js"></script>
</body>
</html>