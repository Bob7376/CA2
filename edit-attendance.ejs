<!DOCTYPE html>
<html lang="en">
<head>
    <meta charset="UTF-8">
    <meta name="viewport" content="width=device-width, initial-scale=1.0">
    <title>Admin - Organize Classes</title>
    <link href="https://cdn.jsdelivr.net/npm/bootstrap@5.3.0/dist/css/bootstrap.min.css" rel="stylesheet">
</head>
<body class="bg-light">

    <%- include('partials/navbar') %>

<div class="container mt-4">
    <div class="card shadow-sm border-0 mb-4 bg-dark text-white">
        <div class="card-body d-flex justify-content-between align-items-center">
            <div>
                <h3 class="mb-0">Class Organizer</h3>
                <p class="text-light-50 small mb-0">Select students below to organize them into custom groups.</p>
            </div>
            <!-- Simple Inline Action Box -->
            <div class="d-flex gap-2">
                <input type="text" id="targetGroupName" class="form-control form-control-sm" placeholder="Enter Group Name (e.g., Group A)">
                <button type="button" class="btn btn-primary btn-sm text-nowrap" onclick="assignToGroup()">Assign Group</button>
            </div>
        </div>
    </div>

    <!-- Grouped Lists -->
    <% 
        // 1. Group the students array by group_name using Javascript inside EJS
        const groups = {};
        students.forEach(student => {
            const gName = student.group_name || 'Unassigned';
            if (!groups[gName]) {
                groups[gName] = [];
            }
            groups[gName].push(student);
        });

        // 2. Loop through each group and display them in separate cards
        Object.keys(groups).forEach(function(groupName) { 
    %>
        <div class="card shadow-sm border-0 mb-4">
            <!-- Group Header -->
            <div class="card-header d-flex justify-content-between align-items-center <%= groupName === 'Unassigned' ? 'bg-secondary text-white' : 'bg-primary text-white' %>">
                <h5 class="mb-0">📁 <%= groupName %></h5>
                <span class="badge bg-light text-dark"><%= groups[groupName].length %> Students</span>
            </div>
            
            <!-- Group Table -->
            <div class="card-body p-0">
                <div class="table-responsive">
                    <table class="table table-hover align-middle mb-0">
                        <thead>
                            <tr class="table-light">
                                <th style="width: 5%;" class="ps-3">Select</th>
                                <th style="width: 25%;">Student ID</th>
                                <th style="width: 40%;">Full Name</th>
                                <th style="width: 15%;">Assigned Class</th>
                                <th style="width: 15%;">Session</th>
                            </tr>
                        </thead>
                        <tbody>
                            <% groups[groupName].forEach(function(student) { %>
                                <tr>
                                    <td class="ps-3">
                                        <input type="checkbox" class="form-check-input student-checkbox" value="<%= student.student_id %>">
                                    </td>
                                    <td><code><%= student.student_id %></code></td>
                                    <td class="fw-semibold"><%= student.student_name %></td>
                                    <td><span class="badge bg-light text-dark border">Class <%= student.class_id %></span></td>
                                    <td><%= student.session ? 'Session ' + student.session : 'N/A' %></td>
                                </tr>
                            <% }) %>
                        </tbody>
                    </table>
                </div>
            </div>
        </div>
    <% }) %>
</div>

<script>
function assignToGroup() {
    const groupNameInput = document.getElementById('targetGroupName');
    const groupName = groupNameInput.value.trim();
    
    if (!groupName) {
        alert('Please type a group name first!');
        return;
    }

    const checkboxes = document.querySelectorAll('.student-checkbox:checked');
    if (checkboxes.length === 0) {
        alert('Please select at least one student checkbox.');
        return;
    }

    const selectedIds = Array.from(checkboxes).map(cb => cb.value);

    // Send the group update to the database
    fetch('/admin/assign-group', {
        method: 'POST',
        headers: { 'Content-Type': 'application/json' },
        body: JSON.stringify({ groupName: groupName, studentIds: selectedIds })
    })
    .then(res => res.json())
    .then(data => {
        if (data.success) {
            window.location.reload(); // Refresh to see the student jump to their new visual group card!
        } else {
            alert('Failed to save group assignment.');
        }
    })
    .catch(err => console.error(err));
}
</script>
   